#include <stdio.h>

int main() {
    char str[100];
    int seen[26] = {0};  // for lowercase letters

    printf("Enter string: ");
    scanf("%s", str);

    for(int i = 0; str[i] != '\0'; i++) {
        int index = str[i] - 'a';

        if(seen[index] == 1) {
            printf("%c\n", str[i]);
            return 0;
        }

        seen[index] = 1;
    }

    printf("-1\n");
    return 0;
}
