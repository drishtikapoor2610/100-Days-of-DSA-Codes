#include <stdio.h>

int main() 
{
    int n, low, high, mid, ans=0;

    printf("Enter number: ");
    scanf("%d",&n);

    low = 0;
    high = n;

    while(low <= high)
    {
        mid = (low + high)/2;

        if(mid * mid == n)
        {
            ans = mid;
            break;
        }
        else if(mid * mid < n)
        {
            ans = mid;      // possible integer sqrt
            low = mid + 1;
        }
        else
        {
            high = mid - 1;
        }
    }

    printf("Integer square root = %d",ans);

    return 0;
}
